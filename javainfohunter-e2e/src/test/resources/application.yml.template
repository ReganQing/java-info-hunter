# E2E Test Configuration Template
# Copy this file to application-local.yml and configure with your local settings

spring:
  application:
    name: javainfohunter-e2e

  # Database configuration
  # WARNING: Use strong passwords for production!
  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5432}/${DB_NAME:javainfohunter_test}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: org.postgresql.Driver

  # JPA configuration
  jpa:
    hpa:
      ddl-auto: create-drop
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

  # Flyway (disabled for E2E tests)
  flyway:
    enabled: false

  # RabbitMQ configuration
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: ${RABBITMQ_PORT:5672}
    username: ${RABBITMQ_USERNAME}
    password: ${RABBITMQ_PASSWORD}
    publisher-confirm-type: correlated
    publisher-returns: true

  # Redis configuration
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      timeout: 3000ms
      lettuce:
        pool:
          max-active: 8
          max-idle: 8
          min-idle: 0

  # AI Service Configuration
  ai:
    dashscope:
      api-key: ${DASHSCOPE_API_KEY:DISABLED-AI-KEY-NOT-CONFIGURED}
      enabled: ${AI_ENABLED:false}

# Application configuration
javainfohunter:
  ai:
    enabled: ${AI_ENABLED:false}
    agent:
      max-steps: 10
      timeout: 300

  # RabbitMQ configuration
  rabbitmq:
    exchange:
      crawled-content: x.crawled-content
      processed-content: x.processed-content
    queue:
      raw-content: q.raw-content
      processed-content: q.processed-content
    routing-key:
      crawled-content: rk.crawled-content
      processed-content: rk.processed-content

# Logging configuration
logging:
  level:
    com.ron.javainfohunter: ${LOG_LEVEL:INFO}
    org.springframework.amqp: ${RABBITMQ_LOG_LEVEL:INFO}
    org.hibernate.SQL: WARN
    org.hibernate.type.descriptor.sql.BasicBinder: WARN
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} - %msg%n"

# Actuator configuration
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: always
