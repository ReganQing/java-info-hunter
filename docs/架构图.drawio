  <diagram name="功能架构图" id="functional-architecture">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 标题 -->
        <mxCell id="title-func" value="JavaInfoHunter 功能架构图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        <!-- 核心功能层 -->
        <mxCell id="core-function-layer" value="核心功能层" style="swimlane;fontSize=14;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1E1E1E;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="800" height="300" as="geometry" />
        </mxCell>
        <mxCell id="url-mgmt" value="URL 管理&lt;br&gt;&lt;br&gt;• RSS 源订阅管理&lt;br&gt;• 爬取任务调度&lt;br&gt;• 频率控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="core-function-layer">
          <mxGeometry x="30" y="40" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="content-crawler" value="内容采集&lt;br&gt;&lt;br&gt;• HTML 解析&lt;br&gt;• 正文提取&lt;br&gt;• 元数据提取" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="core-function-layer">
          <mxGeometry x="200" y="40" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="content-process" value="内容处理&lt;br&gt;&lt;br&gt;• 去重清洗&lt;br&gt;• AI 摘要生成&lt;br&gt;• 内容分类" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="core-function-layer">
          <mxGeometry x="370" y="40" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="vector-storage" value="向量存储&lt;br&gt;&lt;br&gt;• 文本向量化&lt;br&gt;• 相似度计算&lt;br&gt;• 语义索引" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="core-function-layer">
          <mxGeometry x="540" y="40" width="150" height="100" as="geometry" />
        </mxCell>
        <!-- 扩展功能 -->
        <mxCell id="extension-sublayer" value="扩展功能" style="swimlane;fontSize=12;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="core-function-layer">
          <mxGeometry x="30" y="160" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="recommendation" value="智能推荐&lt;br&gt;个性化推荐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="extension-sublayer">
          <mxGeometry x="30" y="40" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="semantic-search" value="语义搜索&lt;br&gt;自然语言查询" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="extension-sublayer">
          <mxGeometry x="150" y="40" width="100" height="60" as="geometry" />
