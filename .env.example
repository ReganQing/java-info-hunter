# JavaInfoHunter Environment Variables Template
# Copy this file to .env and configure with your actual values
# IMPORTANT: Never commit .env file to version control!

# ========================================
# Database Configuration
# ========================================
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=javainfohunter

# ========================================
# RabbitMQ Configuration
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_secure_rabbitmq_password

# ========================================
# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# ========================================
# AI Service Configuration
# ========================================
# Alibaba DashScope API Key
# Get your key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Enable/disable AI features
AI_ENABLED=true

# ========================================
# Application Configuration
# ========================================
# Server port (default: 8080)
SERVER_PORT=8080

# Active profile (dev, staging, prod)
SPRING_PROFILES_ACTIVE=dev

# Logging level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ========================================
# Security Configuration
# ========================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_generate_with_openssl

# JWT Expiration (in milliseconds, default: 86400000 = 24 hours)
JWT_EXPIRATION=86400000
